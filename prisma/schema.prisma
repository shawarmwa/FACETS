generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
  FACULTY
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  evaluations   Evaluation[] @relation("SubmittedBy")
  facultyScores Evaluation[] @relation("FacultyEvaluated")
}

model Evaluation {
  id            String   @id @default(cuid())
  rating        Int
  feedback      String
  courseCode    String
  createdAt     DateTime @default(now())
  submittedById String
  facultyId     String
  submittedBy   User     @relation("SubmittedBy", fields: [submittedById], references: [id])
  faculty       User     @relation("FacultyEvaluated", fields: [facultyId], references: [id])

  @@index([facultyId])
  @@index([submittedById])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
